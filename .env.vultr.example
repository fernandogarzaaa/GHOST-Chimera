# Copy to .env.vultr on the Vultr VM and fill in real values there.
# Do not commit .env.vultr.

COMPOSE_PROJECT_NAME=ghost-chimera-vultr

# Public demo console guardrail. Use a long random value.
GHOSTCHIMERA_CONSOLE_AUTH_TOKEN=replace-with-long-random-demo-token

# Production guardrails required by `ghostchimera doctor --production`.
GHOSTCHIMERA_DEPLOYMENT_MODE=production
GHOSTCHIMERA_EXTERNAL_ISOLATION=container
GHOSTCHIMERA_SECURITY_REVIEWED=1
GHOSTCHIMERA_HUMAN_APPROVAL_REQUIRED=1
GHOSTCHIMERA_ALLOW_UNTRUSTED_INPUTS=0

# Demo runtime posture: the judge can inspect and preview agentic workflows,
# but risky local execution surfaces remain gated by production policy.
GHOSTCHIMERA_MODEL_PROVIDER=vultr
GHOSTCHIMERA_STATE_DIR=/data/state

# Optional Vultr Serverless Inference. Leave blank to run deterministic/local
# demo routes only; the Vultr provider will report unavailable until all three
# values are set.
VULTR_INFERENCE_API_KEY=
VULTR_INFERENCE_MODEL=
VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1/chat/completions
