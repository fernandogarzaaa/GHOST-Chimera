# Copy to .env.production and replace placeholder values before deployment.
# Do not commit .env.production.

COMPOSE_PROJECT_NAME=ghost-chimera

# Required console access token. Replace before validating or deploying.
GHOSTCHIMERA_CONSOLE_AUTH_TOKEN=replace-with-long-random-production-token

# Production guardrails required by `ghostchimera doctor --production`.
GHOSTCHIMERA_DEPLOYMENT_MODE=production
GHOSTCHIMERA_EXTERNAL_ISOLATION=container
GHOSTCHIMERA_SECURITY_REVIEWED=1
GHOSTCHIMERA_HUMAN_APPROVAL_REQUIRED=1
GHOSTCHIMERA_ALLOW_UNTRUSTED_INPUTS=0

# Persist runtime state inside the container volume.
GHOSTCHIMERA_STATE_DIR=/data/state

# Choose one model provider and fill in its required values.
GHOSTCHIMERA_MODEL_PROVIDER=vultr

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Vultr Serverless Inference
VULTR_INFERENCE_API_KEY=
VULTR_INFERENCE_MODEL=
VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1/chat/completions
