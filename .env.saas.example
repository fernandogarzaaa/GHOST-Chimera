GHOSTCHIMERA_DEPLOYMENT_TARGET=saas
GHOSTCHIMERA_DEPLOYMENT_MODE=production
GHOSTCHIMERA_EXTERNAL_ISOLATION=container
GHOSTCHIMERA_SECURITY_REVIEWED=1
GHOSTCHIMERA_HUMAN_APPROVAL_REQUIRED=1
GHOSTCHIMERA_CONSOLE_AUTH_TOKEN=replace-with-random-token

GHOSTCHIMERA_DATABASE_URL=postgresql://ghostchimera:replace-with-db-password@postgres:5432/ghostchimera
GHOSTCHIMERA_OIDC_ISSUER=https://issuer.example.com
GHOSTCHIMERA_OIDC_CLIENT_ID=replace-with-oidc-client-id
GHOSTCHIMERA_OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
GHOSTCHIMERA_OIDC_REDIRECT_URI=https://ghost.example.com/oauth/callback
GHOSTCHIMERA_OIDC_ALLOWED_DOMAINS=example.com
GHOSTCHIMERA_ADMIN_BOOTSTRAP_EMAIL=owner@example.com
GHOSTCHIMERA_SESSION_SECRET=replace-with-session-secret
GHOSTCHIMERA_SECRETS_ENCRYPTION_KEY=replace-with-32-byte-secret
GHOSTCHIMERA_WORKER_TOKEN=replace-with-worker-token

GHOSTCHIMERA_MODEL_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

POSTGRES_DB=ghostchimera
POSTGRES_USER=ghostchimera
POSTGRES_PASSWORD=replace-with-db-password
